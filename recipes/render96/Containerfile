FROM registry.fedoraproject.org/fedora:latest

ARG baserom_variant=us

# Pinned upstream sources for reproducibility.
# Bump these deliberately after testing.
ARG render96ex_commit=cd02b8886e0a0498c23b0c1f1e58f0b7c70ccc66
ARG texpack_commit=239156bea1903ca15989d1e7143a88b32e9f1b99
ARG modelpack_version=3.25

# Install build dependencies
RUN dnf install -y \
    gcc \
    gcc-c++ \
    make \
    python3 \
    SDL2-devel \
    glew-devel \
    git \
    p7zip \
    util-linux \
    && dnf clean all

# Clone Render96ex pinned to a specific commit on the alpha branch
RUN git clone https://github.com/Render96/Render96ex.git /opt/render96ex && \
    cd /opt/render96ex && \
    git checkout ${render96ex_commit}

WORKDIR /opt/render96ex

# Copy in the user-supplied ROM
COPY baserom.${baserom_variant}.z64 /opt/render96ex/baserom.${baserom_variant}.z64

# Build the port.
# The tools/ subdirectory has a parallel-build race condition (tabledesign
# tries to link libaudiofile.a before it's finished building), so build tools
# sequentially first, then do the main build in parallel.
RUN make -C tools -j1 && \
    make VERSION=${baserom_variant} BETTERCAMERA=1 EXTERNAL_DATA=1 EXT_OPTIONS_MENU=1 TEXTURE_FIX=1 NODRAWINGDISTANCE=1 -j$(nproc)

# Fetch and install the Render96 model pack into DynOS packs directory
RUN curl -L -o /tmp/modelpack.7z \
    https://github.com/Render96/ModelPack/releases/download/${modelpack_version}/Render96_DynOs_v${modelpack_version}.7z && \
    mkdir -p /opt/render96ex/build/${baserom_variant}_pc/dynos/packs && \
    7za x /tmp/modelpack.7z -o/opt/render96ex/build/${baserom_variant}_pc/dynos/packs && \
    rm /tmp/modelpack.7z

# Fetch and install the HD texture pack pinned to a specific commit
RUN git clone https://github.com/pokeheadroom/RENDER96-HD-TEXTURE-PACK.git /tmp/texpack && \
    cd /tmp/texpack && \
    git checkout ${texpack_commit} && \
    mkdir -p /opt/render96ex/build/${baserom_variant}_pc/res/gfx && \
    cp -r /tmp/texpack/gfx/* /opt/render96ex/build/${baserom_variant}_pc/res/gfx/ && \
    rm -rf /tmp/texpack

# Move runtime artifacts to a clean location.
# Render96 needs the binary, res/ (with HD textures), and dynos/ (with model packs).
RUN mkdir -p /opt/sm64 && \
    cp /opt/render96ex/build/${baserom_variant}_pc/sm64.${baserom_variant}.f3dex2e /opt/sm64/ && \
    cp -r /opt/render96ex/build/${baserom_variant}_pc/res /opt/sm64/res && \
    cp -r /opt/render96ex/build/${baserom_variant}_pc/dynos /opt/sm64/dynos && \
    echo "${baserom_variant}" > /opt/sm64/.variant

# Clean up build artifacts and source to save space
RUN rm -rf /opt/render96ex && \
    dnf remove -y gcc gcc-c++ make git p7zip && \
    dnf autoremove -y && \
    dnf clean all

WORKDIR /opt/sm64
