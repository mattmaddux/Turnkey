FROM registry.fedoraproject.org/fedora:latest

ARG baserom_variant=us
ARG nodrawingdistance=true
ARG texturefixes=true

# Install build dependencies
RUN dnf install -y \
    gcc \
    gcc-c++ \
    make \
    python3 \
    SDL2-devel \
    glew-devel \
    git \
    util-linux \
    && dnf clean all

# Clone sm64ex
RUN git clone --depth 1 https://github.com/sm64pc/sm64ex.git /opt/sm64ex

WORKDIR /opt/sm64ex

# Copy in the user-supplied ROM (filename set by the CLI based on detected variant)
COPY baserom.${baserom_variant}.z64 /opt/sm64ex/baserom.${baserom_variant}.z64

# Build with opinionated defaults
RUN MAKE_FLAGS="VERSION=${baserom_variant} BETTERCAMERA=1 EXTERNAL_DATA=1 EXT_OPTIONS_MENU=1" && \
    if [ "$nodrawingdistance" = "true" ]; then MAKE_FLAGS="$MAKE_FLAGS NODRAWINGDISTANCE=1"; fi && \
    if [ "$texturefixes" = "true" ]; then MAKE_FLAGS="$MAKE_FLAGS TEXTURE_FIX=1"; fi && \
    make $MAKE_FLAGS -j$(nproc)

# Move only the runtime artifacts to a clean location.
# With EXTERNAL_DATA=1, the binary loads assets from the `res/` directory
# placed next to it. Everything else in build/${variant}_pc is build intermediate.
RUN mkdir -p /opt/sm64 && \
    cp /opt/sm64ex/build/${baserom_variant}_pc/sm64.${baserom_variant}.f3dex2e /opt/sm64/ && \
    cp -r /opt/sm64ex/build/${baserom_variant}_pc/res /opt/sm64/res && \
    echo "${baserom_variant}" > /opt/sm64/.variant

# Clean up build artifacts and source to save space
RUN rm -rf /opt/sm64ex && \
    dnf remove -y gcc gcc-c++ make git && \
    dnf autoremove -y && \
    dnf clean all

WORKDIR /opt/sm64
